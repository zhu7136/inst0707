+class Hyperparams:
+    def __init__(self):
+        # fields for extracting critical joint and links
+        self.link_of_interests = [
+            "left_shoulder_yaw_link",
+            "right_shoulder_yaw_link",
+            "left_elbow_link",
+            "right_elbow_link",
+            "left_wrist_yaw_link",
+            "right_wrist_yaw_link",
+            "pelvis",
+            "torso_link",
+            "left_hip_yaw_link",
+            "right_hip_yaw_link",
+            "left_knee_link",
+            "right_knee_link",
+            "left_ankle_roll_link",
+            "right_ankle_roll_link",
+        ]
+
+        self.knee_joint_names = [
+            "left_knee_joint",
+            "right_knee_joint",
+        ]
+
+        self.foot_link_names = [
+            "left_ankle_roll_link",
+            "right_ankle_roll_link",
+        ]
+
+        self.torso_link_name = "torso_link"
+
+        # fields for filtering and thresholds
+        self.root_z_valid_range = [0.0, 1.5]
+        self.root_z_debatable_range = [0.9, 1.8]
+        self.root_z_debatable_length_s = 1.0
+        # radians that the joint position is within the range of joint limits. If negative, the joint positions are
+        # allowed to be out of limits.
+        self.joint_limit_threshold = 0.01
+
+        # fields for checking sit pose
+        self.sit_pose_reference_joint_pos = {
+            "left_hip_pitch_joint": -1.57,
+            "right_hip_pitch_joint": -1.57,
+            "left_knee_joint": 1.57,
+            "right_knee_joint": 1.57,
+        }
+        self.sit_pose_joint_pos_threshold = 0.2
+
+    def to_dict(self):
+        """Return the hyparameters as a dictionary for saving"""
+        return self.__dict__
+
+    def from_dict(self, di):
+        """Load the hyparameters from a dictionary"""
+        self.__dict__.update(di)
+
+
+class RetargetedDatasetFilter:
+    def __init__(self, args):
+        self.args = args
+        self.params = Hyperparams()
+
+    def load_robot_model(self):
+        """Main function for filtering the AMASS dataset"""
+        # load the robot model
+        with open(self.args.urdf_path, mode="rb") as f:
+            urdf_str = f.read()
+        self.robot_chain = pk.build_chain_from_urdf(urdf_str)
+        self.joint_limits_low, self.joint_limits_high = self.robot_chain.get_joint_limits()  # (num_joints,)
+        self.joint_limits_low = torch.as_tensor(self.joint_limits_low)
+        self.joint_limits_high = torch.as_tensor(self.joint_limits_high)
+        self.joint_names = [j.name for j in self.robot_chain.get_joints()]
+        self.knee_joint_idxs = [self.joint_names.index(name) for name in self.params.knee_joint_names]
+        self.foot_link_idxs = [self.joint_names.index(name) for name in self.params.foot_link_names]
+        self.torso_link_idx = self.joint_names.index(self.params.torso_link_name)
+
+    def check_root_z_validity(self, motion) -> bool:
+        """Check if the root z is valid."""
+        root_z = motion["base_pos_w"][:, 2]  # (T,)
+        return (root_z > self.params.root_z_valid_range[0]).all() and (root_z < self.params.root_z_valid_range[1]).all()
+
+    def check_root_z_debatable(self, motion) -> bool:
+        """Check if the root z is continuously in the debatable range lower than the time length."""
+        root_z = motion["base_pos_w"][:, 2]  # (T,)
+        debatable_mask = (root_z > self.params.root_z_debatable_range[0]) & (
+            root_z < self.params.root_z_debatable_range[1]
+        )
+
+        # Find the longest continuous segment in the debatable range
+        if not debatable_mask.any():
+            return False
+
+        # Find contiguous segments of True values
+        # Using numpy's diff to find changes in the mask
+        mask_changes = np.diff(np.r_[False, debatable_mask, False].astype(int))
+        segment_starts = np.where(mask_changes == 1)[0]
+        segment_ends = np.where(mask_changes == -1)[0]
+
+        # Calculate segment lengths
+        segment_lengths = segment_ends - segment_starts
+        max_continuous_frames = segment_lengths.max() if len(segment_lengths) > 0 else 0
+
+        # Check if any continuous segment exceeds the time threshold
+        return max_continuous_frames <= self.params.root_z_debatable_length_s * motion["framerate"]
+
+    def check_joint_limit(self, motion) -> bool:
+        """Check if the joint positions are within the joint limits."""
+        joint_pos = motion["joint_pos"]  # (T, num_joints)
+        return (joint_pos > (self.joint_limits_low + self.params.joint_limit_threshold)).all() and (
+            joint_pos < (self.joint_limits_high - self.params.joint_limit_threshold)
+        ).all()
+
+    def check_sit_pose(self, motion) -> bool:
+        """Check if the motion is a sit pose. Return True if the motion does not contain any sit pose."""
+
+    def filter_motion_file(self, filepath):
+        """Load motion files from npz file.
+        File content:
+            - framerate: float scalar
+            - joint_names: list of joint names
+            - joint_pos: array of joint positions. Shape is (N, num_joints)
+            - base_pos_w: array of base positions. Shape is (N, 3)
+            - base_quat_w: array of base quaternions. Shape is (N, 4) in qw, qx, qy, qz
+        """
+        motion = np.load(filepath, allow_pickle=True)
+
+        return all(
+            [
+                self.check_root_z_validity(motion),
+                self.check_root_z_debatable(motion),
+                self.check_joint_limit(motion),
+            ]
         )
